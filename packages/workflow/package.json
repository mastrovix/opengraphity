{
  "name": "@opengraphity/workflow",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "seed": "tsx src/seed.ts",
    "seed:change": "tsx src/seed-change-runner.ts",
    "seed:kb": "tsx src/seed-kb-runner.ts",
    "seed:problem": "tsx src/seed-problem.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@opengraphity/events": "workspace:*",
    "@opengraphity/neo4j": "workspace:*",
    "@opengraphity/types": "workspace:*",
    "bullmq": "^5.0.0",
    "pino": "^10.3.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.5",
    "@types/node": "^20.12.0",
    "@types/uuid": "^9.0.0",
    "neo4j-driver": "^5.19.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.0"
  }
}
