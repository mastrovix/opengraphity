# ── OpenGraphity Docker environment ───────────────────────────────────────────
# Copy to infra/.env and fill in your values:
#   cp infra/.env.example infra/.env

# ── Security (CHANGE IN PRODUCTION) ──────────────────────────────────────────
JWT_SECRET=change-me-in-production
NEO4J_PASSWORD=opengraphity_local

# Discovery credential encryption key (32-byte hex string, optional)
DISCOVERY_ENCRYPTION_KEY=

# ── Keycloak ──────────────────────────────────────────────────────────────────
KEYCLOAK_REALM=master
KEYCLOAK_CLIENT_ID=opengrafo-api
KEYCLOAK_CLIENT_SECRET=

# ── Frontend build args ───────────────────────────────────────────────────────
# Keycloak URL reachable by the browser (not internal Docker hostname)
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_CLIENT_ID=opengrafo-web
VITE_KEYCLOAK_CLIENT_ID_PORTAL=opengrafo-portal
# Tenant slug shown in the portal when not using subdomain routing
VITE_TENANT_SLUG=

# ── API options ───────────────────────────────────────────────────────────────
LOG_LEVEL=info
OTEL_ENABLED=false
CORS_ORIGIN=http://localhost:5173
APP_URL=http://localhost:5173

# ── Optional integrations ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_WEBHOOK_URL=
