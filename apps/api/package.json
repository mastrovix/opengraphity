{
  "name": "@opengraphity/api",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "seed:teams": "tsx src/scripts/seed-teams.ts",
    "seed:users-bulk": "tsx src/scripts/seed-users-bulk.ts",
    "seed:apps": "tsx src/scripts/seed-apps.ts",
    "seed:apps-with-teams": "tsx src/scripts/seed-apps-with-teams.ts",
    "seed:databases": "tsx src/scripts/seed-databases.ts",
    "seed:databases-with-teams": "tsx src/scripts/seed-databases-with-teams.ts",
    "seed:servers": "tsx src/scripts/seed-servers.ts",
    "seed:servers-with-teams": "tsx src/scripts/seed-servers-with-teams.ts",
    "seed:dbinstances": "tsx src/scripts/seed-database-instances.ts",
    "seed:dbinstances-with-teams": "tsx src/scripts/seed-dbinstances-with-teams.ts",
    "seed:relations": "tsx src/scripts/seed-relations.ts",
    "seed:ci-relations": "tsx src/scripts/seed-ci-relations.ts",
    "seed:app-relations": "tsx src/scripts/seed-app-relations.ts",
    "seed:certificates": "tsx src/scripts/seed-certificates.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@apollo/server": "^4.10.0",
    "@opengraphity/events": "workspace:*",
    "@opengraphity/neo4j": "workspace:*",
    "@opengraphity/notifications": "workspace:*",
    "@opengraphity/scripting": "workspace:*",
    "@opengraphity/sla": "workspace:*",
    "@opengraphity/types": "workspace:*",
    "@opengraphity/workflow": "workspace:*",
    "@slack/web-api": "^7.14.1",
    "cors": "^2.8.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "graphql": "^16.8.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "jwks-rsa": "^4.0.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.0",
    "@types/uuid": "^9.0.8",
    "@vitest/coverage-v8": "^4.1.0",
    "jest-mock-extended": "^4.0.0",
    "neo4j-driver": "^5.28.3",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.1"
  }
}
